{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bmat.dev/contracts/bundle-manifest.schema.json",
  "title": "BMAT Release Bundle Manifest v2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "manifest_id",
    "plugin_version",
    "workflow_run_id",
    "generated_at",
    "entries"
  ],
  "properties": {
    "schema_version": { "const": "2.0" },
    "manifest_id": { "type": "string", "minLength": 1 },
    "plugin_version": { "type": "string", "minLength": 1 },
    "workflow_run_id": { "type": "string", "minLength": 1 },
    "generated_at": { "type": "string", "format": "date-time" },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "artifact_type",
          "path",
          "sha256",
          "size_bytes",
          "schema_version",
          "plugin_version",
          "workflow_run_id",
          "required_for_release",
          "generated_at"
        ],
        "properties": {
          "artifact_type": { "type": "string", "minLength": 1 },
          "path": {
            "type": "string",
            "minLength": 1,
            "pattern": "^(?![A-Za-z]:)(?![/\\\\])(?!.*(?:^|[/\\\\])\\.\\.(?:[/\\\\]|$)).+$"
          },
          "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
          "size_bytes": { "type": "integer", "minimum": 0 },
          "schema_version": { "type": "string", "minLength": 1 },
          "plugin_version": { "type": "string", "minLength": 1 },
          "workflow_run_id": { "type": "string", "minLength": 1 },
          "required_for_release": { "type": "boolean" },
          "generated_at": { "type": "string", "format": "date-time" }
        }
      }
    }
  }
}
