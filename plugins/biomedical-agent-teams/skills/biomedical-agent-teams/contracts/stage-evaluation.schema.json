{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Biomedical Agent Teams Stage Evaluation",
  "type": "object",
  "additionalProperties": false,
  "required": ["evaluation_id", "workflow_alias", "stages", "overall_verdict"],
  "properties": {
    "evaluation_id": { "type": "string" },
    "workflow_alias": { "type": "string" },
    "stages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["stage_id", "stage_name", "status", "evidence", "blocking_issues"],
        "properties": {
          "stage_id": {
            "type": "string",
            "enum": ["S1", "S2", "S3", "S4", "S5", "other"]
          },
          "stage_name": { "type": "string" },
          "status": {
            "type": "string",
            "enum": ["pass", "pass-with-caveats", "skipped", "block", "not-applicable"]
          },
          "score": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "evidence": { "type": "string" },
          "blocking_issues": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "overall_verdict": {
      "type": "string",
      "enum": ["pass", "pass-with-caveats", "block", "not-assessable"]
    },
    "downgrade_rule_applied": { "type": "string" }
  }
}
