{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Biomedical Agent Teams Workflow Run",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "run_id",
    "alias",
    "mode",
    "plugin_version",
    "stages",
    "final_label",
    "downgrade_reasons"
  ],
  "properties": {
    "run_id": { "type": "string" },
    "alias": { "type": "string" },
    "mode": {
      "type": "string",
      "enum": ["quick", "standard", "deep", "audit", "plan", "run"]
    },
    "plugin_version": { "type": "string" },
    "stages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "required", "status", "evidence"],
        "properties": {
          "id": { "type": "string" },
          "required": { "type": "boolean" },
          "status": {
            "type": "string",
            "enum": ["pass", "pass-with-caveats", "skipped", "block", "not-applicable"]
          },
          "evidence": { "type": "string" },
          "depends_on": {
            "type": "array",
            "items": { "type": "string" }
          },
          "block_condition": { "type": "string" }
        }
      }
    },
    "final_label": {
      "type": "string",
      "enum": [
        "Full protocol followed",
        "Compact standard workflow",
        "Biomedical Agent Teams-informed narrative review",
        "Partial workflow; formal gates skipped",
        "Blocked"
      ]
    },
    "downgrade_reasons": {
      "type": "array",
      "items": { "type": "string" }
    },
    "artifacts_root": { "type": "string" },
    "resume_pointer": { "type": "string" }
  }
}
