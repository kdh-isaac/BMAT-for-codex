{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Biomedical Agent Teams Preflight Contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "runtime_capability_preflight_id",
    "plugin_version",
    "workflow_run_id",
    "created_at",
    "requested_alias",
    "selected_mode",
    "deliverable_type",
    "evidence_scope",
    "risk_class",
    "selected_domain_pack",
    "domain_pack_version",
    "selection_reason",
    "domain_specific_assumptions",
    "required_role_outputs",
    "skipped_role_outputs_with_reason",
    "external_tools_allowed",
    "file_write_plan",
    "stop_criteria",
    "checkpoint_plan",
    "execution_strategy",
    "spawned_review_plan",
    "team_spawn_plan",
    "all_role_spawn_avoidance_reason",
    "nested_spawn_policy",
    "post_team_audit_plan"
  ],
  "properties": {
    "schema_version": { "const": "2.0" },
    "runtime_capability_preflight_id": {
      "type": "string"
    },
    "runtime_id": {
      "type": "string"
    },
    "codex_client": {
      "type": "string"
    },
    "plugin_version": {
      "type": "string"
    },
    "created_at": { "type": "string", "format": "date-time" },
    "workspace_root": {
      "type": "string"
    },
    "host_os": {
      "type": "string"
    },
    "path_style": {
      "type": "string",
      "enum": ["posix", "windows", "mixed", "unknown", "not-applicable"]
    },
    "python_invocation": {
      "type": "string"
    },
    "shell_family": {
      "type": "string",
      "enum": ["bash", "zsh", "powershell", "cmd", "none", "unknown", "not-applicable"]
    },
    "codex_runtime_capability_surface": {
      "type": "array",
      "items": { "type": "string" }
    },
    "capabilities": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "web_search_available",
        "shell_available",
        "file_read_available",
        "file_write_available",
        "network_available"
      ],
      "properties": {
        "web_search_available": { "$ref": "#/$defs/availability" },
        "shell_available": { "$ref": "#/$defs/availability" },
        "file_read_available": { "$ref": "#/$defs/availability" },
        "file_write_available": { "$ref": "#/$defs/availability" },
        "network_available": { "$ref": "#/$defs/availability" }
      }
    },
    "external_bio_tools_available": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/availability" }
    },
    "validator_cli_available": { "$ref": "#/$defs/availability" },
    "pairwise_ranking_script_available": { "$ref": "#/$defs/availability" },
    "tool_registry_available": { "$ref": "#/$defs/availability" },
    "results_integration_available": { "$ref": "#/$defs/availability" },
    "iteration_budget_available": { "$ref": "#/$defs/availability" },
    "compute_budget": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "mode": { "type": "string" },
        "iteration_budget": { "type": "integer", "minimum": 1 },
        "max_candidates": { "type": "integer", "minimum": 1 },
        "max_pairwise_matches": { "type": "integer", "minimum": 0 },
        "max_spawned_reviewers": { "type": "integer", "minimum": 0 },
        "max_external_queries": { "type": "integer", "minimum": 0 }
      }
    },
    "validator_unavailable_reason": {
      "type": "string",
      "enum": [
        "none",
        "validator_unavailable_due_to_runtime",
        "missing_bundle",
        "missing_jsonschema",
        "not-applicable"
      ]
    },
    "spawned_subagents_supported": { "$ref": "#/$defs/availability" },
    "sandbox_profile": { "type": "string" },
    "label_ceiling_due_to_runtime": {
      "type": "string",
      "enum": [
        "Full protocol followed",
        "Contract-shaped artifact bundle",
        "Compact standard workflow",
        "Limited capability-downgraded workflow",
        "Blocked"
      ]
    },
    "downgrade_rule": {
      "type": "string"
    },
    "notes": {
      "type": "array",
      "items": { "type": "string" }
    },
    "requested_alias": {
      "type": "string"
    },
    "selected_mode": {
      "type": "string",
      "enum": ["quick", "standard", "deep", "audit", "plan", "run"]
    },
    "deliverable_type": {
      "type": "string"
    },
    "domain_pack": {
      "type": "string"
    },
    "selected_domain_pack": {
      "type": "string",
      "enum": ["generic-biomedical", "cell-therapy", "immuno-oncology"]
    },
    "domain_pack_version": {
      "type": "string"
    },
    "selection_reason": { "type": "string", "minLength": 1 },
    "domain_specific_assumptions": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "workflow_tier": {
      "type": "string",
      "enum": ["compact", "full"]
    },
    "requested_omics_track": {
      "type": "string",
      "enum": [
        "bulk-rnaseq",
        "tenx-gex",
        "tenx-cellplex",
        "tenx-citeseq",
        "tenx-vdj",
        "tenx-multiome",
        "single-cell-other",
        "survival",
        "multi-omics",
        "other",
        "not-applicable",
        "track_ambiguous"
      ]
    },
    "omics_track_ambiguity_note": {
      "type": "string"
    },
    "domain_specific_failure_modes_loaded": {
      "oneOf": [
        { "type": "boolean" },
        { "$ref": "#/$defs/availability" }
      ]
    },
    "domain_assumptions_skipped": {
      "type": "array",
      "items": { "type": "string" }
    },
    "workflow_dag_id": {
      "type": "string"
    },
    "results_integration_required": {
      "type": "boolean"
    },
    "evidence_scope": {
      "type": "object",
      "additionalProperties": true,
      "required": ["source_types", "species_or_model", "date_or_version_needs"],
      "properties": {
        "source_types": {
          "type": "array",
          "items": { "type": "string" }
        },
        "species_or_model": {
          "type": "string"
        },
        "date_or_version_needs": {
          "type": "string"
        }
      }
    },
    "risk_class": {
      "type": "string",
      "enum": ["low", "moderate", "high"]
    },
    "required_role_outputs": {
      "type": "array",
      "items": { "type": "string" }
    },
    "skipped_role_outputs_with_reason": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["reason_code", "reason_detail", "affected_roles", "downgrade_label", "approved_by", "recorded_at"],
        "properties": {
          "role": { "type": "string" },
          "reason": { "type": "string" },
          "reason_code": {
            "type": "string",
            "enum": ["RUNTIME_NO_SPAWN_SUPPORT", "TOOL_REVIEW_UNAVAILABLE", "PRIVACY_BLOCKED", "USER_COMPACT_INLINE_ONLY", "EXPLICITLY_OUT_OF_SCOPE", "BUDGET_BLOCKED", "HUMAN_GATE_BLOCKED"]
          },
          "reason_detail": { "type": "string", "minLength": 1 },
          "affected_roles": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
          "downgrade_label": {
            "type": "string",
            "enum": ["Contract-shaped artifact bundle", "Compact standard workflow", "Biomedical Agent Teams-informed narrative review", "Limited capability-downgraded workflow", "Partial workflow; formal gates skipped", "Blocked"]
          },
          "approved_by": { "type": "string", "minLength": 1 },
          "recorded_at": { "type": "string", "format": "date-time" }
        }
      }
    },
    "external_tools_allowed": {
      "type": "object",
      "additionalProperties": false,
      "required": ["allowed", "limits"],
      "properties": {
        "allowed": { "type": "boolean" },
        "limits": { "type": "string" }
      }
    },
    "file_write_plan": {
      "type": "object",
      "additionalProperties": false,
      "required": ["will_write_files", "allowed_paths"],
      "properties": {
        "will_write_files": { "type": "boolean" },
        "allowed_paths": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "stop_criteria": {
      "type": "array",
      "items": { "type": "string" }
    },
    "checkpoint_plan": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["checkpoint", "required_before"],
        "properties": {
          "checkpoint": { "type": "string" },
          "required_before": { "type": "string" }
        }
      }
    },
    "execution_strategy": {
      "type": "string",
      "enum": [
        "inline_only",
        "inline_first_selective_review",
        "team_level_selective_dag",
        "user_requested_full_spawn",
        "blocked"
      ]
    },
    "spawned_review_plan": {
      "type": "object",
      "additionalProperties": false,
      "required": ["allowed", "budget", "selected_roles", "rationale"],
      "properties": {
        "allowed": { "type": "boolean" },
        "budget": { "type": "integer", "minimum": 0 },
        "selected_roles": {
          "type": "array",
          "items": { "type": "string" }
        },
        "rationale": { "type": "string" }
      }
    },
    "team_spawn_plan": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "allowed",
        "budget",
        "selected_teams",
        "dependency_graph",
        "nested_spawn_allowed",
        "rationale"
      ],
      "properties": {
        "allowed": { "type": "boolean" },
        "budget": { "type": "integer", "minimum": 0 },
        "selected_teams": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "biomedical-research-council",
              "idea-discovery-team",
              "omics-analysis-team",
              "evidence-audit-team",
              "experiment-design-team",
              "translational-scout-team"
            ]
          }
        },
        "dependency_graph": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["team", "phase", "depends_on", "purpose"],
            "properties": {
              "team": { "type": "string" },
              "phase": { "type": "integer", "minimum": 0 },
              "depends_on": {
                "type": "array",
                "items": { "type": "string" }
              },
              "purpose": { "type": "string" }
            }
          }
        },
        "nested_spawn_allowed": { "type": "boolean" },
        "rationale": { "type": "string" }
      }
    },
    "all_role_spawn_avoidance_reason": {
      "type": "string"
    },
    "nested_spawn_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["allowed", "authorization", "limits"],
      "properties": {
        "allowed": { "type": "boolean" },
        "authorization": { "type": "string" },
        "limits": { "type": "string" }
      }
    },
    "post_team_audit_plan": {
      "type": "string"
    },
    "source_corpus_id": {
      "type": "string"
    },
    "workflow_run_id": {
      "type": "string"
    }
  },
  "$defs": {
    "availability": {
      "type": "string",
      "enum": ["yes", "no", "unknown", "not-applicable"]
    }
  }
}
