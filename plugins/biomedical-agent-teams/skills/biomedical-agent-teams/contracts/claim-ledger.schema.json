{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Biomedical Agent Teams Claim Ledger",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "claim_ledger_id", "plugin_version", "workflow_run_id", "created_at", "claims"],
  "properties": {
    "schema_version": { "const": "2.0" },
    "claim_ledger_id": { "type": "string", "minLength": 1 },
    "plugin_version": { "type": "string", "minLength": 1 },
    "workflow_run_id": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "format": "date-time" },
    "claims": {
      "type": "array",
      "items": { "$ref": "#/$defs/claim" }
    },
    "claim_ledger": {
      "type": "array",
      "items": { "$ref": "#/$defs/claim" }
    },
    "rows": {
      "type": "array",
      "items": { "$ref": "#/$defs/claim" }
    },
    "excluded_or_not_verified_claims": {
      "type": "array",
      "items": { "type": "object" }
    }
  },
  "$defs": {
    "scopeVerdict": {
      "type": "string",
      "enum": ["match", "partial", "mismatch", "not-applicable", "not-assessed"]
    },
    "claim": {
      "type": "object",
      "additionalProperties": true,
      "required": ["claim_id", "atomic_claim"],
      "properties": {
        "claim_id": { "type": "string" },
        "atomic_claim": { "type": "string" },
        "claim_type": { "type": "string" },
        "claim_profile": {
          "type": "string",
          "enum": ["draft", "source_backed", "tool_backed", "analysis_backed", "high_confidence", "blocked"]
        },
        "context": { "type": "string" },
        "source_backed": { "type": ["boolean", "string"] },
        "source_id": { "type": "string" },
        "source_ids": {
          "type": "array",
          "items": { "type": "string" }
        },
        "evidence_items": {
          "type": "array",
          "items": {
            "oneOf": [
              { "type": "string" },
              { "type": "object" }
            ]
          }
        },
        "evidence_relation": { "type": "string" },
        "uncertainty": { "type": "string" },
        "audit_status": { "type": "string" },
        "allowed_final_wording": { "type": "string" },
        "claim_strength": { "type": "string" },
        "tool_backed": { "type": "boolean" },
        "tool_id": { "type": "string" },
        "tool_ids": {
          "type": "array",
          "items": { "type": "string" }
        },
        "result_id": { "type": "string" },
        "result_ids": {
          "type": "array",
          "items": { "type": "string" }
        },
        "analysis_backed": { "type": "boolean" },
        "block_reason": { "type": "string" },
        "entity_ids": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "evidence_edges": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["subject", "predicate", "object", "source_id"],
            "properties": {
              "subject": { "type": "string" },
              "predicate": { "type": "string" },
              "object": { "type": "string" },
              "source_id": { "type": "string" },
              "evidence_span_ref": { "type": "string" }
            }
          }
        },
        "scope_match": {
          "type": "object",
          "additionalProperties": false,
          "required": ["species", "cell_type", "assay", "endpoint", "population_or_model", "intervention_or_exposure", "biological_context"],
          "properties": {
            "species": { "$ref": "#/$defs/scopeVerdict" },
            "cell_type": { "$ref": "#/$defs/scopeVerdict" },
            "assay": { "$ref": "#/$defs/scopeVerdict" },
            "endpoint": { "$ref": "#/$defs/scopeVerdict" },
            "population_or_model": { "$ref": "#/$defs/scopeVerdict" },
            "intervention_or_exposure": { "$ref": "#/$defs/scopeVerdict" },
            "biological_context": { "$ref": "#/$defs/scopeVerdict" }
          }
        },
        "entailment_verdict": {
          "type": "string",
          "enum": ["supports", "weakly-supports", "contradicts", "irrelevant", "not-checked"]
        }
      }
    }
  }
}
