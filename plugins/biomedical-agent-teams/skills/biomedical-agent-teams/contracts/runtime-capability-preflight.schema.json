{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Biomedical Agent Teams Runtime Capability Preflight",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "runtime_id",
    "codex_client",
    "plugin_version",
    "workspace_root",
    "capabilities",
    "external_bio_tools_available",
    "spawned_subagents_supported",
    "sandbox_profile",
    "downgrade_rule"
  ],
  "properties": {
    "runtime_id": { "type": "string" },
    "codex_client": { "type": "string" },
    "plugin_version": { "type": "string" },
    "workspace_root": { "type": "string" },
    "capabilities": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "web_search_available",
        "shell_available",
        "file_read_available",
        "file_write_available",
        "network_available"
      ],
      "properties": {
        "web_search_available": { "$ref": "#/$defs/availability" },
        "shell_available": { "$ref": "#/$defs/availability" },
        "file_read_available": { "$ref": "#/$defs/availability" },
        "file_write_available": { "$ref": "#/$defs/availability" },
        "network_available": { "$ref": "#/$defs/availability" }
      }
    },
    "external_bio_tools_available": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/availability" }
    },
    "spawned_subagents_supported": { "$ref": "#/$defs/availability" },
    "sandbox_profile": { "type": "string" },
    "downgrade_rule": { "type": "string" },
    "notes": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "$defs": {
    "availability": {
      "type": "string",
      "enum": ["yes", "no", "unknown", "not-applicable"]
    }
  }
}
