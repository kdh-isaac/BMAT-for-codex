{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Biomedical Agent Teams Spawned Agent Output",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "objective",
    "assigned_scope",
    "inputs_checked",
    "tools_skills_commands_or_databases_used",
    "key_findings",
    "contradictions_or_risks",
    "confidence",
    "files_changed_or_none",
    "checks_run_or_skipped",
    "recommended_handoff",
    "affected_claim_ids",
    "verdict",
    "ledger_handoff"
  ],
  "properties": {
    "objective": { "type": "string" },
    "assigned_scope": { "type": "string" },
    "inputs_checked": {
      "type": "array",
      "items": { "type": "string" }
    },
    "tools_skills_commands_or_databases_used": {
      "type": "array",
      "items": { "type": "string" }
    },
    "key_findings": {
      "type": "array",
      "items": { "type": "string" }
    },
    "contradictions_or_risks": {
      "type": "array",
      "items": { "type": "string" }
    },
    "confidence": {
      "type": "string",
      "enum": ["low", "medium", "high", "not-assessable"]
    },
    "files_changed_or_none": { "type": "string" },
    "checks_run_or_skipped": {
      "type": "array",
      "items": { "type": "string" }
    },
    "recommended_handoff": { "type": "string" },
    "affected_claim_ids": {
      "type": "array",
      "items": { "type": "string" }
    },
    "verdict": {
      "type": "string",
      "enum": ["pass", "pass-with-caveats", "pass-with-revisions", "block", "not-assessable"]
    },
    "ledger_handoff": { "type": "string" }
  }
}
