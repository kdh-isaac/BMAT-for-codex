{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Biomedical Agent Teams Experiment Design",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "design_id",
    "workflow_run_id",
    "plugin_version",
    "hypothesis",
    "experimental_objective",
    "experimental_unit",
    "primary_endpoint",
    "positive_controls",
    "negative_controls",
    "vehicle_or_mock_controls",
    "biological_replicates",
    "technical_replicates",
    "randomization",
    "blinding",
    "exclusion_criteria",
    "confounders",
    "causal_kill_tests",
    "statistical_plan",
    "go_no_go_gates",
    "safety_ethics_privacy_boundary",
    "reagent_provenance_policy",
    "source_ids",
    "claim_ids_supported"
  ],
  "properties": {
    "design_id": { "type": "string" },
    "workflow_run_id": { "type": "string" },
    "plugin_version": { "type": "string" },
    "hypothesis": { "type": "string" },
    "experimental_objective": { "type": "string" },
    "experimental_unit": {
      "type": "object",
      "required": ["unit_type", "justification"],
      "properties": {
        "unit_type": { "type": "string" },
        "justification": { "type": "string" }
      },
      "additionalProperties": true
    },
    "primary_endpoint": { "type": "string" },
    "secondary_endpoints": { "type": "array", "items": { "type": "string" } },
    "positive_controls": { "type": "array", "items": { "type": "string" } },
    "negative_controls": { "type": "array", "items": { "type": "string" } },
    "vehicle_or_mock_controls": { "type": "array", "items": { "type": "string" } },
    "biological_replicates": { "type": "object", "additionalProperties": true },
    "technical_replicates": { "type": "object", "additionalProperties": true },
    "randomization": { "type": "object", "additionalProperties": true },
    "blinding": { "type": "object", "additionalProperties": true },
    "exclusion_criteria": { "type": "array", "items": { "type": "string" } },
    "confounders": { "type": "array", "items": { "type": "string" } },
    "causal_kill_tests": { "type": "array", "items": { "type": "string" } },
    "statistical_plan": { "type": "object", "additionalProperties": true },
    "go_no_go_gates": { "type": "array", "items": { "type": "string" } },
    "safety_ethics_privacy_boundary": { "type": "string" },
    "reagent_provenance_policy": { "type": "string" },
    "source_ids": { "type": "array", "items": { "type": "string" } },
    "claim_ids_supported": { "type": "array", "items": { "type": "string" } }
  }
}
