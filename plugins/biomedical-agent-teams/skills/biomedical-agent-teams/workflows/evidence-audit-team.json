{
  "workflow_id": "evidence-audit-team.audit",
  "runtime": "codex",
  "alias": "evidence-audit-team",
  "mode": "audit",
  "track": "claim-evidence-audit",
  "nodes": [
    {
      "id": "S0_context_lock",
      "agent": "protocol-context-locker",
      "outputs": ["runtime_capability_preflight", "workflow_run"],
      "blocking": true
    },
    {
      "id": "S1_source_corpus",
      "agent": "life-science-literature-curator",
      "requires": ["S0_context_lock"],
      "outputs": ["source_corpus"],
      "blocking": true
    },
    {
      "id": "S2_claim_ledger",
      "agent": "central-claim-ledger-evidence-graph",
      "requires": ["S1_source_corpus"],
      "outputs": ["claim_ledger"],
      "blocking": true
    },
    {
      "id": "S3_citation_check",
      "agent": "citation-verifier",
      "requires": ["S2_claim_ledger"],
      "outputs": ["results_integration"],
      "blocking": true,
      "spawnable": true,
      "toml_template_path": "codex-agents/citation-verifier.toml",
      "independence_required": true
    },
    {
      "id": "S4_contradiction_check",
      "agent": "contradiction-red-team",
      "requires": ["S3_citation_check"],
      "outputs": ["stage_evaluation"],
      "blocking": true,
      "spawnable": true,
      "toml_template_path": "codex-agents/contradiction-red-team.toml",
      "independence_required": true
    },
    {
      "id": "S5_post_write",
      "agent": "post-write-final-validator",
      "requires": ["S4_contradiction_check"],
      "outputs": ["post_write_validation", "final_text"],
      "blocking": true,
      "spawnable": true,
      "toml_template_path": "codex-agents/post-write-final-validator.toml",
      "independence_required": true
    }
  ],
  "release_gates": ["bmat_validate", "bmat_tool_ledger_check"]
}
